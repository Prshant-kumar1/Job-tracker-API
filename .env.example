# Copy this file to .env and fill in real values before running in production.

# Secret key used to sign JWTs. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_IN_PRODUCTION

# JWT signing algorithm
ALGORITHM=HS256

# Access token lifetime, in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database connection string (SQLite by default — no setup required)
DATABASE_URL=sqlite:///./job_tracker.db
